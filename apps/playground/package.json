{
  "name": "playground",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "clean": "rm -rf node_modules .next .turbo playwright-report test-results",
    "lint": "eslint && tsc --noEmit",
    "test:vr": "playwright test",
    "test:vr:ui": "playwright test --ui",
    "test:vr:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/themes": "workspace:*",
    "next": "^16.2.3",
    "next-themes": "0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-use": "^17.6.0",
    "seedrandom": "3.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.3",
    "typescript": "^6.0.2"
  }
}
